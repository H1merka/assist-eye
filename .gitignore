# ======================================================
# assist-eye .gitignore
# Flutter/Dart + Python (ML-скрипты)
# ======================================================

# ------------------- Flutter / Dart -------------------

# Сгенерированные файлы
*.dart_tool/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
.pub-cache/
.pub/
pubspec.lock

# Генерация кода
*.g.dart
*.freezed.dart

# Платформенные сборки (генерируются flutter create)
# Не игнорируем android/ и ios/ — они нужны в репозитории
# после генерации через `flutter create .`

# Покрытие тестов
coverage/
*.lcov

# ------------------- Android -------------------
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
**/android/**/*.keystore
**/android/**/*.jks
!**/android/gradle/wrapper/gradle-wrapper.jar

# ------------------- iOS -------------------
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/DerivedData/
**/ios/.symlinks/
**/ios/**/Flutter/App.framework
**/ios/**/Flutter/Flutter.framework
**/ios/**/Flutter/Flutter.podspec
**/ios/**/Flutter/Generated.xcconfig
**/ios/**/Flutter/ephemeral/
**/ios/**/Flutter/app.flx
**/ios/**/Flutter/app.zip
**/ios/**/Flutter/flutter_assets/
**/ios/**/Pods/
**/ios/**/.symlinks/

# ------------------- Python (ML-скрипты) -------------------

__pycache__/
*.py[codz]
*$py.class
*.so

# Виртуальные окружения
.env
.envrc
.venv/
env/
venv/
ENV/

# Дистрибуция
*.egg-info/
*.egg
dist/
wheels/

# Тестирование / покрытие
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Типизация
.mypy_cache/
.pytype/
.pyre/

# Ruff
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# ------------------- ML-модели -------------------
# Модели загружаются отдельно (§7.7 ТЗ), не включать в репозиторий
*.tflite
*.onnx
*.pb
*.h5
*.savedmodel/
# Исключение: labelmap-файлы нужны
!assets/models/*.txt

# Датасеты (большие, не коммитить)
data/
datasets/

# ------------------- IDE -------------------

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (Android Studio, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# ------------------- OS -------------------

.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ------------------- Логи -------------------
*.log

# Extras
.github/
extra/
