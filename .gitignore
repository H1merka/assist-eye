# ======================================================
# assist-eye .gitignore
# React Native + TypeScript + Python (ML-скрипты)
# ======================================================

# ------------------- React Native / JS / TS -------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# Metro bundler
.metro-health-check*

# Build output
*.jsbundle
*.jsbundle.map

# Покрытие тестов
coverage/
*.lcov

# ------------------- Android & iOS (Expo Prebuild) -------------------
android/
ios/


# ------------------- Python (ML-скрипты) -------------------

__pycache__/
*.py[codz]
*$py.class
*.so

# Виртуальные окружения
.envrc
.venv/
env/
venv/
ENV/

# Дистрибуция
*.egg-info/
*.egg
dist/
wheels/

# Тестирование / покрытие
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Типизация
.mypy_cache/
.pytype/
.pyre/

# Ruff
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# ------------------- ML-модели -------------------
# Модели загружаются отдельно (§7.7 ТЗ), не включать в репозиторий
*.tflite
*.onnx
*.pb
*.h5
*.savedmodel/
# Исключение: labelmap-файлы нужны
!assets/models/*.txt

# Датасеты (большие, не коммитить)
data/
datasets/

# ------------------- Env / Secrets -------------------
.env
.env.local
.env.production

# ------------------- IDE -------------------

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (Android Studio, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# ------------------- OS -------------------

.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ------------------- Логи -------------------
*.log

# User ignores
.github/
project_docs/
assets/

# Expo
.expo/
dist/
web-build/

# Vosk archives and directories
assets/models/vosk-*
*.zip
*.tar.gz

# Google Service / Firebase
google-services.json
GoogleService-Info.plist

# React Native / Metro
.rncache
haste-map-* 
metro-cache/

# Keys' artifacts
*.mobileprovision
*.pem
*.p12
