{
  "name": "assist-eye",
  "version": "0.1.0",
  "private": true,
  "description": "Мобильное приложение для помощи слабовидящим и незрячим — голосовое управление, OCR, детекция объектов, определение купюр. Полностью офлайн.",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "clean": "react-native clean",
    "test": "jest",
    "test:accessibility": "jest --testPathPattern=accessibility",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "typecheck": "tsc --noEmit",
    "validate": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-native": "^0.76.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "react-native-screens": "^4.4.0",
    "react-native-safe-area-context": "^5.0.0",
    "zustand": "^5.0.0",
    "react-native-vision-camera": "^4.6.0",
    "react-native-fast-tflite": "^1.4.0",
    "react-native-vosk": "^0.2.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "react-native-tts": "^4.1.0",
    "react-native-sqlite-storage": "^6.0.0",
    "react-native-keychain": "^9.2.0",
    "react-native-permissions": "^4.1.0",
    "react-native-haptic-feedback": "^2.3.0",
    "react-native-shake": "^5.6.0",
    "react-native-sound": "^0.11.0",
    "react-native-fs": "^2.20.0",
    "i18next": "^24.0.0",
    "react-i18next": "^15.0.0",
    "react-native-localize": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.76.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.6.0",
    "jest": "^29.7.0",
    "@testing-library/react-native": "^12.7.0",
    "@testing-library/jest-native": "^5.4.0",
    "react-test-renderer": "^18.3.1",
    "eslint": "^9.0.0",
    "@react-native/eslint-config": "^0.76.0",
    "prettier": "^3.4.0",
    "@react-native/metro-config": "^0.76.0",
    "@react-native/babel-preset": "^0.76.0",
    "@react-native/typescript-config": "^0.76.0",
    "babel-jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
