# ======================================================
# assist-eye — переменные окружения
# ======================================================
# Скопируйте в .env и заполните значения.
# НИКОГДА не коммитьте .env в репозиторий!

# URL для скачивания ML-моделей (Vosk, TFLite)
MODEL_DOWNLOAD_BASE_URL=https://github.com/H1merka/assist-eye/releases/download/models

# Feature flags (true / false)
FEATURE_BANKNOTE_CLASSIFIER=false
FEATURE_ONBOARDING=false
FEATURE_OBJECT_POSITION=false

# Yandex MapKit API Key
EXPO_PUBLIC_YANDEX_MAPKIT_API_KEY=your_yandex_mapkit_key_here
